# Master Profile Configuration
# Set the path to your master profile JSON file
# Use absolute path or project-relative path
MASTER_PROFILE_PATH=data/master_profile.json

# AI Provider Configuration
# Supported providers: gemini
AI_PROVIDER=gemini
AI_MODEL=gemini-1.5-flash-latest

# API Keys (required based on provider)
# For Gemini:
GEMINI_API_KEY=your_gemini_api_key_here